{
    "name": "zubzet/framework",
    "description": " A lightweight PHP framework focused on rapid development, ease of use, and great portability.",
    "license": "Apache-2.0",
    "support": {
        "wiki": "https://zubzet.com/docs"
    },
    "require": {
        "php": ">=8.0 <8.6",
        "zubzet/password-hash-utilities": "1.0.*",
        "cakephp/database": "^4.5",
        "nikic/fast-route": "^1.3",
        "phpmailer/phpmailer": "^6.7",
        "symfony/console": "7.* || 6.*",
        "doctrine/dbal": "^3.10 || ^4.4",
        "monolog/monolog": "^2.11",
        "phpunit/php-code-coverage": "9.*"
    },
    "autoload": {
        "files": [
            "src/Aliases.php"
        ],
        "psr-4": {
            "ZubZet\\Framework\\": "src/"
        }
    }
}
