{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Dev Environment",
            "type": "shell",
            "command": "npm run startup",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Stop Dev Environment",
            "type": "shell",
            "command": "npm run stop",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
