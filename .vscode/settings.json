{
    "cSpell.words": [
        "katana"
    ],
    "path-mapper": [
        {
            "match": "/var/www/framework/",
            "replace": "${workspaceFolder}/"
        },
        {
            "match": "/var/www/html/",
            "replace": "${workspaceFolder}/tests/e2e/"
        },
        {
            "match": "/var/www/vendor/",
            "replace": "${workspaceFolder}/vendor/"
        }
    ]
}